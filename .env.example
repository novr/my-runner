# GitHub App configuration
# App ID: GitHub → Settings → Developer settings → GitHub Apps → Your App → App ID
GITHUB_APP_ID=123456

# Installation ID: run once to find it →
#   gh api /orgs/{org}/installation --jq '.id'
GITHUB_APP_INSTALLATION_ID=78901234

# Absolute path to the private key .pem downloaded from the App settings page.
# Store outside the repository to avoid accidental commits.
GITHUB_APP_PRIVATE_KEY_PATH=/etc/github-runner/private-key.pem

# Org-level runners (recommended): set GITHUB_ORG, leave GITHUB_REPO empty
# Repo-level runners: set GITHUB_REPO=owner/repo, leave GITHUB_ORG empty
GITHUB_ORG=your-org
GITHUB_REPO=

RUNNER_GROUP_ID=1
RUNNER_LABELS=macos,tart,xcode,self-hosted

# VM configuration
BASE_IMAGE=ghcr.io/cirruslabs/macos-sequoia-xcode:latest
VM_CPU=4
VM_MEMORY=8192   # MB

# Pool configuration
POOL_SIZE=2      # Number of runner VMs to keep listening at all times

# GitHub Actions runner binary version
# See: https://github.com/actions/runner/releases
RUNNER_VERSION=2.322.0
