# ── Authentication ────────────────────────────────────────────────────────────
# Option A: GitHub Apps (recommended for production)
#   App ID shown on the App settings page.
#   Installation ID: gh api /orgs/{org}/installation --jq '.id'
#     ※ This endpoint requires App JWT auth — use Option B temporarily to find it,
#       or look at the URL in GitHub → Org Settings → GitHub Apps → Configure.
GITHUB_APP_ID=
GITHUB_APP_INSTALLATION_ID=
# Absolute path to the .pem downloaded from App settings. Keep outside this repo.
GITHUB_APP_PRIVATE_KEY_PATH=/etc/github-runner/private-key.pem

# Option B: Personal Access Token (fine-grained)
#   Required scopes: Organization self-hosted runners → Read & Write
GITHUB_TOKEN=

# ── Target ────────────────────────────────────────────────────────────────────
# Org-level runners: set GITHUB_ORG, leave GITHUB_REPO empty.
# Repo-level runners: set GITHUB_REPO=owner/repo, leave GITHUB_ORG empty.
GITHUB_ORG=novr
GITHUB_REPO=

RUNNER_GROUP_ID=1
RUNNER_LABELS=macos,tart,xcode,self-hosted

# ── VM ────────────────────────────────────────────────────────────────────────
BASE_IMAGE=ghcr.io/cirruslabs/macos-sequoia-xcode:latest
VM_CPU=4
VM_MEMORY=8192   # MB

# ── Pool ──────────────────────────────────────────────────────────────────────
POOL_SIZE=2      # Number of runner VMs to keep listening at all times

# ── Runner binary ─────────────────────────────────────────────────────────────
# https://github.com/actions/runner/releases
RUNNER_VERSION=2.322.0
